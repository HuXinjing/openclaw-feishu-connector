# ============================================================
# Feishu Application Credentials
# Required: Get from Feishu Open Platform → Your App → Credentials
# ============================================================
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Only needed for HTTP event subscription (not required for WebSocket mode)
# FEISHU_ENCRYPT_KEY=
# FEISHU_VERIFICATION_TOKEN=

# ============================================================
# Server Configuration
# ============================================================
# CONNECTOR_PORT=3000
# ADMIN_PORT=3001

# ============================================================
# Docker Configuration
# ============================================================
# DOCKER_HOST=localhost          # Leave unset to use Docker socket mount
# DOCKER_PORT=2375
OPENCLAW_IMAGE=openclaw/openclaw:latest
DATA_DIR=./data/users
GATEWAY_BASE_PORT=18790

# ============================================================
# Security — Generate with: openssl rand -hex 24
# ============================================================
HOOKS_TOKEN_SALT=your-random-64-char-hex-salt-change-this

# Admin JWT signing secret — Generate with: openssl rand -hex 32
ADMIN_JWT_SECRET=your-64-char-hex-jwt-secret-change-this
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password-in-production

# User Access Token (UAT) encryption key — Generate with: openssl rand -hex 32
UAT_MASTER_KEY=your-32-char-hex-encryption-key-change-this

# Bridge plugin auth token (used for inter-service communication)
BRIDGE_TOKEN=your-bridge-token-change-this

# ============================================================
# Database — MySQL (production, recommended)
# ============================================================
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=feishu_connector

# Legacy: SQLite mode only (ignored when MYSQL_HOST is set)
# USER_MAP_DB=./data/connector/users.db

# ============================================================
# AI Provider (optional)
# ============================================================
# MINIMAX_API_KEY=sk-your-minimax-api-key

# ============================================================
# Bridge Plugin (optional)
# ============================================================
# BRIDGE_PLUGIN_DIR=/path/to/bridge-plugin

# Connector URL for Bridge/containers to reach this service
# When running inside Docker, use host.docker.internal
CONNECTOR_URL=http://host.docker.internal:3000

# Public URL for OAuth callbacks (e.g. https://your-domain.com or ngrok URL)
# CONNECTOR_PUBLIC_URL=https://your-public-url.example.com

# ============================================================
# Container Pool Settings (optional)
# ============================================================
# POOL_SIZE=2
# AUTO_WARM_POOL=false
# CONTAINER_SLEEP_ENABLED=true
# CONTAINER_SESSION_IDLE_BUFFER_MS=600000
# CONTAINER_CRON_LOOKAHEAD_MS=43200000
# OFFBOARD_CLEANUP_INTERVAL_MS=86400000
